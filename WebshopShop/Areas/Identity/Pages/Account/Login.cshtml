@page
@model LoginModel

@{
ViewData["Title"] = "Sign in";
Layout = "/Views/Shared/_StorefrontLayout.cshtml";
}

<div class="sf-page">
    <div style="max-width: 400px; margin: 4rem auto;">

        <div style="margin-bottom: 2rem;">
            <p class="sf-hero-tag">Welcome back</p>
            <h1 class="sf-detail-title">Sign in</h1>
            <p class="sf-detail-description" style="margin-bottom: 0;">Don't have an account? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" style="color:#888; text-decoration:none;">Register here</a></p>
        </div>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" style="font-size:12px; color:#cc4444; margin-bottom:16px;"></div>

            <div class="sf-form-group">
                <label asp-for="Input.Email" class="sf-form-label">Email</label>
                <input asp-for="Input.Email" class="sf-form-input" autocomplete="username" placeholder="name@example.com" />
                <span asp-validation-for="Input.Email" class="sf-form-error"></span>
            </div>

            <div class="sf-form-group">
                <label asp-for="Input.Password" class="sf-form-label">Password</label>
                <input asp-for="Input.Password" class="sf-form-input" autocomplete="current-password" placeholder="••••••••" />
                <span asp-validation-for="Input.Password" class="sf-form-error"></span>
            </div>

            <div class="sf-form-group" style="display:flex; align-items:center; gap:8px;">
                <input class="sf-form-checkbox" asp-for="Input.RememberMe" type="checkbox" style="width:14px; height:14px; accent-color:#fff; cursor:pointer;" />
                <label asp-for="Input.RememberMe" class="sf-form-label" style="margin:0;">Remember me</label>
            </div>

            <button id="login-submit" type="submit" class="sf-detail-btn" style="width:100%; margin-top:8px;">
                Sign in
            </button>

            <div style="margin-top: 1.5rem; display: flex; flex-direction: column; gap: 8px;">
                <a id="forgot-password" asp-page="./ForgotPassword" style="font-size:13px; color:#444; text-decoration:none; transition: color 0.15s;">Forgot your password?</a>
                <a id="resend-confirmation" asp-page="./ResendEmailConfirmation" style="font-size:13px; color:#444; text-decoration:none; transition: color 0.15s;">Resend email confirmation</a>
            </div>
        </form>

    </div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
}