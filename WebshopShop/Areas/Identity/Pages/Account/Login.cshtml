@page
@model LoginModel

@{
    ViewData["Title"] = "Sign in";
    Layout = "/Views/Shared/_StorefrontLayout.cshtml";
}

<div class="sf-page">
    <div class="sf-auth">

        <div class="sf-auth-header">
            <p class="sf-hero-tag">Welcome back</p>
            <h1 class="sf-detail-title">Sign in</h1>
            <p class="sf-detail-description">
                Don't have an account?
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="sf-link">Register here</a>
            </p>
        </div>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="sf-form-error"></div>

            <div class="sf-form-group">
                <label asp-for="Input.EmailOrUsername" class="sf-form-label">Email or Username</label>
                <input asp-for="Input.EmailOrUsername" class="sf-form-input"
                       autocomplete="username"
                       placeholder="name@example.com or john_doe" />
                <span asp-validation-for="Input.EmailOrUsername" class="sf-form-error"></span>
            </div>

            <div class="sf-form-group">
                <label asp-for="Input.Password" class="sf-form-label">Password</label>
                <input asp-for="Input.Password" class="sf-form-input"
                       autocomplete="current-password"
                       placeholder="••••••••" />
                <span asp-validation-for="Input.Password" class="sf-form-error"></span>
            </div>

            <div class="sf-checkbox-row">
                <input asp-for="Input.RememberMe" type="checkbox" id="remember-me" />
                <label asp-for="Input.RememberMe" for="remember-me">Remember me</label>
            </div>

            <button id="login-submit" type="submit" class="sf-detail-btn sf-detail-btn-block">
                Sign in
            </button>

            <div class="sf-auth-links">
                <a asp-page="./ForgotPassword">Forgot your password?</a>
                <a asp-page="./ResendEmailConfirmation">Resend email confirmation</a>
            </div>
        </form>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
