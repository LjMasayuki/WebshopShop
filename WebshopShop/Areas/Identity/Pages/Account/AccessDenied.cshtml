@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Access Denied";
    Layout = "/Views/Shared/_StorefrontLayout.cshtml";
}

<div class="sf-page">
    <div class="sf-error">
        <p class="sf-error-code">403</p>
        <h1 class="sf-error-title">Access Denied</h1>
        <p class="sf-error-sub">
            You don't have permission to access this resource.
            If you think this is a mistake, contact an administrator.
        </p>
        <a href="/" class="sf-detail-btn">Back to Browse</a>
    </div>
</div>
