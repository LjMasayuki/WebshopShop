@page
@model LogoutModel
@{
    ViewData["Title"] = "Sign out";
    Layout = "/Views/Shared/_StorefrontLayout.cshtml";
}

<div class="sf-page">
    <div class="sf-error">
        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <p class="sf-error-code">Account</p>
            <h1 class="sf-error-title">Sign Out</h1>
            <p class="sf-error-sub">
                Are you sure you want to sign out of your account?
            </p>

            <form asp-area="Identity" asp-page="/Account/Logout"
                  asp-route-returnUrl="@Url.Page("/", new { area = "" })"
                  method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="sf-detail-btn">Sign Out</button>
            </form>
        }
        else
        {
            <p class="sf-error-code">Goodbye</p>
            <h1 class="sf-error-title">You're signed out</h1>
            <p class="sf-error-sub">
                You have successfully signed out of the application.
            </p>
            <a href="/" class="sf-detail-btn">Back to Browse</a>
        }
    </div>
</div>
