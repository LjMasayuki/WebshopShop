@model WebshopShop.ViewModels.Admin.OrderDetailViewModel

@{
    ViewData["Title"] = "Order Detail";
}

<div class="adm-header">
    <div class="adm-header-left">
        <p class="adm-breadcrumb"><a asp-controller="Admin" asp-action="Orders">Orders</a> / @Model.InvoiceNumber</p>
        <h1 class="adm-title">@Model.InvoiceNumber</h1>
        <p class="adm-subtitle">@Model.IssuedDate.ToString("MMM dd, yyyy · HH:mm") UTC</p>
    </div>
</div>

<div class="adm-two-col-aside">

    <div>
        <div class="adm-table-wrap">

            <table class="adm-table">
                <thead>
                    <tr>
                        <th>Item</th>
                        <th>Price</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td><strong>@item.Title</strong></td>
                            <td>€@item.Price.ToString("0.00")</td>
                        </tr>
                    }
                    <tr class="adm-total-row">
                        <td class="adm-total-label">Total</td>
                        <td class="adm-total-value">€@Model.Total.ToString("0.00")</td>
                    </tr>
                </tbody>
            </table>

            <div class="adm-cards">
                @foreach (var item in Model.Items)
                {
                    <div class="adm-card">
                        <div class="adm-card-row">
                            <span class="adm-card-label">Item</span>
                            <span class="adm-card-value"><strong>@item.Title</strong></span>
                        </div>
                        <div class="adm-card-row">
                            <span class="adm-card-label">Price</span>
                            <span class="adm-card-value">€@item.Price.ToString("0.00")</span>
                        </div>
                    </div>
                }
                <div class="adm-card">
                    <div class="adm-card-row">
                        <span class="adm-card-label">Total</span>
                        <span class="adm-card-value"><strong>€@Model.Total.ToString("0.00")</strong></span>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <aside class="adm-sidebar">

        <div class="adm-info-card">
            <p class="adm-info-card-label">Customer</p>
            <p class="adm-info-card-name">@Model.UserName</p>
            <p class="adm-info-card-line">@Model.Email</p>
        </div>

        <div class="adm-info-card">
            <p class="adm-info-card-label">Shipping Address</p>
            <p class="adm-info-card-name">@Model.CustomerAddress.FirstName @Model.CustomerAddress.LastName</p>
            <p class="adm-info-card-line">@Model.CustomerAddress.AddressLine1</p>
            @if (!string.IsNullOrWhiteSpace(Model.CustomerAddress.AddressLine2))
            {
                <p class="adm-info-card-line">@Model.CustomerAddress.AddressLine2</p>
            }
            <p class="adm-info-card-line">@Model.CustomerAddress.ZipCode @Model.CustomerAddress.City</p>
            <p class="adm-info-card-line">@Model.CustomerAddress.Country</p>
        </div>

    </aside>

</div>
