@model List<WebshopShop.ViewModels.Admin.UserListViewModel>

@{
    ViewData["Title"] = "Users";
}

<div class="adm-header">
    <div class="adm-header-left">
        <p class="adm-breadcrumb">Admin</p>
        <h1 class="adm-title">Users</h1>
        <p class="adm-subtitle">All registered accounts on the platform</p>
    </div>
</div>

<div class="adm-table-wrap">

    <table class="adm-table">
        <thead>
            <tr>
                <th>Username</th>
                <th>Email</th>
                <th>Roles</th>
                <th>Orders</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="5" class="adm-table-empty">No users yet.</td></tr>
            }
            @foreach (var user in Model)
            {
                <tr>
                    <td><strong>@user.UserName</strong></td>
                    <td>@user.Email</td>
                    <td>
                        @if (user.Roles.Any())
                        {
                            foreach (var role in user.Roles)
                            {
                                <span class="adm-badge">@role</span>
                            }
                        }
                        else
                        {
                            <span class="adm-card-label">—</span>
                        }
                    </td>
                    <td><span class="adm-count">@user.OrderCount</span></td>
                    <td>
                        <div class="adm-table-actions">
                            <a asp-controller="Admin" asp-action="EditUserRoles" asp-route-id="@user.Id"
                               class="adm-btn adm-btn-ghost adm-btn-sm">Edit Roles</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="adm-cards">
        @if (!Model.Any())
        {
            <div class="adm-card-empty">No users yet.</div>
        }
        @foreach (var user in Model)
        {
            <div class="adm-card">
                <div class="adm-card-row">
                    <span class="adm-card-label">User</span>
                    <span class="adm-card-value">
                        <strong>@user.UserName</strong>
                        <small>@user.Email</small>
                    </span>
                </div>
                <div class="adm-card-row">
                    <span class="adm-card-label">Roles</span>
                    <span class="adm-card-value">
                        @if (user.Roles.Any())
                        {
                            foreach (var role in user.Roles)
                            {
                                <span class="adm-badge">@role</span>
                            }
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </span>
                </div>
                <div class="adm-card-row">
                    <span class="adm-card-label">Orders</span>
                    <span class="adm-card-value"><span class="adm-count">@user.OrderCount</span></span>
                </div>
                <div class="adm-card-actions">
                    <a asp-controller="Admin" asp-action="EditUserRoles" asp-route-id="@user.Id"
                       class="adm-btn adm-btn-ghost adm-btn-sm">Edit Roles</a>
                </div>
            </div>
        }
    </div>

</div>
