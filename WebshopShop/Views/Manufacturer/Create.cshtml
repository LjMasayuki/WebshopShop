@model WebshopShop.ViewModels.Admin.ManufacturerViewModel

@{
ViewData["Title"] = "Add Developer";
}

<div class="adm-header">
    <div class="adm-header-left">
        <p class="adm-breadcrumb"><a asp-controller="Manufacturer" asp-action="Index">Developers</a> / New</p>
        <h1 class="adm-title">Add Developer</h1>
        <p class="adm-subtitle">Register a developer or agency whose webshops are sold on the platform.</p>
    </div>
</div>

<form asp-controller="Manufacturer" asp-action="Create" method="post" class="adm-form adm-form-narrow">
    @Html.AntiForgeryToken()

    <div class="adm-form-group">
        <label asp-for="Name" class="adm-form-label">Developer / Agency Name</label>
        <input asp-for="Name" class="adm-form-input" placeholder="e.g. Acme Web Studios" />
        <span asp-validation-for="Name" class="adm-form-error"></span>
    </div>

    <div class="adm-form-actions">
        <button type="submit" class="adm-btn adm-btn-primary">Add Developer</button>
        <a asp-controller="Manufacturer" asp-action="Index" class="adm-btn adm-btn-ghost">Cancel</a>
    </div>
</form>