@model WebshopShop.ViewModels.Admin.ManufacturerViewModel

@{
ViewData["Title"] = "Edit Developer";
}

<div class="adm-header">
    <div class="adm-header-left">
        <p class="adm-breadcrumb"><a asp-controller="Manufacturer" asp-action="Index">Developers</a> / Edit</p>
        <h1 class="adm-title">Edit Developer</h1>
        <p class="adm-subtitle">Update the name of this developer or agency.</p>
    </div>
</div>

<form asp-controller="Manufacturer" asp-action="Edit" method="post" class="adm-form adm-form-narrow">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />

    <div class="adm-form-group">
        <label asp-for="Name" class="adm-form-label">Developer / Agency Name</label>
        <input asp-for="Name" class="adm-form-input" />
        <span asp-validation-for="Name" class="adm-form-error"></span>
    </div>

    <div class="adm-form-actions">
        <button type="submit" class="adm-btn adm-btn-primary">Save Changes</button>
        <a asp-controller="Manufacturer" asp-action="Index" class="adm-btn adm-btn-ghost">Cancel</a>
    </div>
</form>