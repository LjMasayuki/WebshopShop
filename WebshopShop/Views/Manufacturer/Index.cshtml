@model IEnumerable<WebshopShop.Models.Manufacturer>

@{
    ViewData["Title"] = "Developers";
}

<div class="adm-header">
    <div class="adm-header-left">
        <p class="adm-breadcrumb">Admin</p>
        <h1 class="adm-title">Developers</h1>
        <p class="adm-subtitle">Studios and freelancers who build the listed webshops</p>
    </div>
    <a asp-controller="Manufacturer" asp-action="Create" class="adm-btn adm-btn-primary">+ Add Developer</a>
</div>

<div class="adm-table-wrap">

    <table class="adm-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Listings</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="3" class="adm-table-empty">No developers yet.</td></tr>
            }
            @foreach (var manufacturer in Model)
            {
                <tr>
                    <td><strong>@manufacturer.Name</strong></td>
                    <td><span class="adm-count">@manufacturer.Items.Count</span></td>
                    <td>
                        <div class="adm-table-actions">
                            <a asp-controller="Manufacturer" asp-action="Edit" asp-route-id="@manufacturer.Id"
                               class="adm-btn adm-btn-ghost adm-btn-sm">Edit</a>
                            <form asp-controller="Manufacturer" asp-action="Delete" asp-route-id="@manufacturer.Id"
                                  method="post" style="display:inline"
                                  onsubmit="return confirm('Delete developer \'@manufacturer.Name\'?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="adm-btn adm-btn-danger adm-btn-sm">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="adm-cards">
        @if (!Model.Any())
        {
            <div class="adm-card-empty">No developers yet.</div>
        }
        @foreach (var manufacturer in Model)
        {
            <div class="adm-card">
                <div class="adm-card-row">
                    <span class="adm-card-label">Name</span>
                    <span class="adm-card-value"><strong>@manufacturer.Name</strong></span>
                </div>
                <div class="adm-card-row">
                    <span class="adm-card-label">Listings</span>
                    <span class="adm-card-value"><span class="adm-count">@manufacturer.Items.Count</span></span>
                </div>
                <div class="adm-card-actions">
                    <a asp-controller="Manufacturer" asp-action="Edit" asp-route-id="@manufacturer.Id"
                       class="adm-btn adm-btn-ghost adm-btn-sm">Edit</a>
                    <form asp-controller="Manufacturer" asp-action="Delete" asp-route-id="@manufacturer.Id"
                          method="post" style="display:inline"
                          onsubmit="return confirm('Delete developer \'@manufacturer.Name\'?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="adm-btn adm-btn-danger adm-btn-sm">Delete</button>
                    </form>
                </div>
            </div>
        }
    </div>

</div>
