@model IEnumerable<WebshopShop.Models.Category>

@{
ViewData["Title"] = "Categories";
}

<div class="adm-header">
    <div class="adm-header-left">
        <p class="adm-breadcrumb">Admin</p>
        <h1 class="adm-title">Categories</h1>
        <p class="adm-subtitle">Webshop types e.g. E-Commerce, SaaS, Portfolio</p>
    </div>
    <a asp-controller="Category" asp-action="Create" class="adm-btn adm-btn-primary">+ Add Category</a>
</div>

<div class="adm-table-wrap" style="max-width: 600px;">
    <table class="adm-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Listings</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
            <tr><td colspan="3" class="adm-table-empty">No categories yet.</td></tr>
            }
            @foreach (var category in Model)
            {
            <tr>
                <td><strong>@category.Name</strong></td>
                <td><span class="adm-count">@category.Items.Count</span></td>
                <td>
                    <div class="adm-table-actions">
                        <a asp-controller="Category" asp-action="Edit" asp-route-id="@category.Id"
                           class="adm-btn adm-btn-ghost adm-btn-sm">Edit</a>
                        <form asp-controller="Category" asp-action="Delete" asp-route-id="@category.Id"
                              method="post" style="display:inline"
                              onsubmit="return confirm('Delete category \'@category.Name\'?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="adm-btn adm-btn-danger adm-btn-sm">Delete</button>
                        </form>
                    </div>
                </td>
            </tr>
            }
        </tbody>
    </table>
</div>