@model IEnumerable<WebshopShop.Models.Category>

@{
    ViewData["Title"] = "Admin — Categories";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0">Categories</h2>
        <small class="text-muted">Webshop types e.g. E-Commerce, SaaS, Portfolio</small>
    </div>
    <a asp-controller="Category" asp-action="Create" class="btn btn-primary">+ Add Category</a>
</div>

<table class="table table-striped table-hover align-middle" style="max-width: 600px;">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Webshops</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var category in Model)
        {
            <tr>
                <td><strong>@category.Name</strong></td>
                <td><span class="text-muted">@category.Items.Count listings</span></td>
                <td class="text-end">
                    <a asp-controller="Category" asp-action="Edit" asp-route-id="@category.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                    <form asp-controller="Category" asp-action="Delete" asp-route-id="@category.Id" method="post" class="d-inline"
                          onsubmit="return confirm('Delete category \'@category.Name\'?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
        @if (!Model.Any())
        {
            <tr>
                <td colspan="3" class="text-center text-muted py-4">No categories yet.</td>
            </tr>
        }
    </tbody>
</table>