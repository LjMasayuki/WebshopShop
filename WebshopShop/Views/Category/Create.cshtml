@model WebshopShop.ViewModels.Admin.CategoryViewModel

@{
ViewData["Title"] = "Add Category";
}

<div class="adm-header">
    <div class="adm-header-left">
        <p class="adm-breadcrumb"><a asp-controller="Category" asp-action="Index">Categories</a> / New</p>
        <h1 class="adm-title">Add Category</h1>
        <p class="adm-subtitle">Create a new webshop type category.</p>
    </div>
</div>

<form asp-controller="Category" asp-action="Create" method="post" class="adm-form adm-form-narrow">
    @Html.AntiForgeryToken()

    <div class="adm-form-group">
        <label asp-for="Name" class="adm-form-label">Category Name</label>
        <input asp-for="Name" class="adm-form-input" placeholder="e.g. E-Commerce" />
        <span asp-validation-for="Name" class="adm-form-error"></span>
    </div>

    <div class="adm-form-actions">
        <button type="submit" class="adm-btn adm-btn-primary">Add Category</button>
        <a asp-controller="Category" asp-action="Index" class="adm-btn adm-btn-ghost">Cancel</a>
    </div>
</form>