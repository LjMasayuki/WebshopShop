@model IEnumerable<WebshopShop.Models.Item>

@{
ViewData["Title"] = "Webshops";
}

<div class="adm-header">
    <div class="adm-header-left">
        <p class="adm-breadcrumb">Admin</p>
        <h1 class="adm-title">Webshops</h1>
        <p class="adm-subtitle">All webshop products listed on the platform</p>
    </div>
    <a asp-controller="Item" asp-action="Create" class="adm-btn adm-btn-primary">+ Add Webshop</a>
</div>

<div class="adm-table-wrap">
    <table class="adm-table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Price</th>
                <th>Category</th>
                <th>Developer</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
            <tr>
                <td colspan="5" class="adm-table-empty">No webshops listed yet. Add your first one.</td>
            </tr>
            }
            @foreach (var item in Model)
            {
            var badgeClass = item.Category.Name.ToLower() switch {
            "saas"      => "adm-badge-saas",
            "portfolio" => "adm-badge-port",
            "blog"      => "adm-badge-blog",
            "crm"       => "adm-badge-crm",
            "finance"   => "adm-badge-fin",
            _           => "adm-badge-ecom"
            };
            <tr>
                <td>
                    <strong>@item.Title</strong>
                    <small>@item.Description.Substring(0, Math.Min(64, item.Description.Length))…</small>
                </td>
                <td>€@item.Price.ToString("0.00")</td>
                <td><span class="adm-badge @badgeClass">@item.Category.Name</span></td>
                <td>@item.Manufacturer.Name</td>
                <td>
                    <div class="adm-table-actions">
                        <a asp-controller="Item" asp-action="Edit" asp-route-id="@item.Id"
                           class="adm-btn adm-btn-ghost adm-btn-sm">Edit</a>
                        <form asp-controller="Item" asp-action="Delete" asp-route-id="@item.Id"
                              method="post" style="display:inline"
                              onsubmit="return confirm('Permanently delete \'@item.Title\'?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="adm-btn adm-btn-danger adm-btn-sm">Delete</button>
                        </form>
                    </div>
                </td>
            </tr>
            }
        </tbody>
    </table>
</div>