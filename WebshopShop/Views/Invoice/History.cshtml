@model WebshopShop.ViewModels.OrderHistoryViewModel

@{
    ViewData["Title"] = "My Orders";
    Layout = "_StorefrontLayout";
}

<div class="sf-page">
    <div class="sf-hero">
        <p class="sf-hero-tag">Account</p>
        <h1 class="sf-hero-title">My Orders</h1>
        <p class="sf-hero-sub">All your past purchases in one place.</p>
    </div>

    @if (!Model.Orders.Any())
    {
        <div class="sf-empty">
            You haven't placed any orders yet.
            <a asp-controller="Home" asp-action="Index" class="sf-link">Start browsing.</a>
        </div>
    }
    else
    {
        <div class="sf-order-list">
            @foreach (var order in Model.Orders)
            {
                <div class="sf-order-card">
                    <div class="sf-order-card-header">
                        <span class="sf-order-number">@order.InvoiceNumber</span>
                        <span class="sf-order-date">@order.IssuedDate.ToString("MMM dd, yyyy")</span>
                    </div>
                    <div class="sf-order-card-body">
                        <p class="sf-order-items">
                            @string.Join(", ", order.ItemTitles)
                        </p>
                        <div class="sf-order-card-footer">
                            <span class="sf-order-total">€@order.Total.ToString("0.00")</span>
                            <div class="sf-order-actions">
                                <a class="sf-btn sf-btn-ghost"
                                   asp-controller="Invoice"
                                   asp-action="DownloadPdf"
                                   asp-route-invoiceId="@order.InvoiceId">
                                    Download PDF
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
