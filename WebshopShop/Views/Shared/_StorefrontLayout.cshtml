<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — WebshopShop</title>
    <link rel="stylesheet" href="~/css/storefront.css" asp-append-version="true" />
</head>
<body class="storefront">

    <nav class="sf-nav">
        <a class="sf-nav-brand" asp-controller="Home" asp-action="Index">WebshopShop</a>
        <ul class="sf-nav-links">
            <li><a asp-controller="Home" asp-action="Index">Browse</a></li>
            @if (User.IsInRole("Admin"))
            {
                <li class="sf-nav-dropdown" style="position:relative;">
                    <a href="#" onclick="this.nextElementSibling.style.display=this.nextElementSibling.style.display==='block'?'none':'block'; return false;"
                       style="font-size:12px; color:#888; text-decoration:none;">Admin ▾</a>
                    <ul style="display:none; position:absolute; top:24px; left:0; background:#141414; border:0.5px solid #2a2a2a; border-radius:6px; padding:6px 0; list-style:none; min-width:160px; z-index:200;">
                        <li><a asp-controller="Item" asp-action="Index" style="display:block;padding:7px 16px;font-size:12px;color:#888;text-decoration:none;">Webshops</a></li>
                        <li><a asp-controller="Category" asp-action="Index" style="display:block;padding:7px 16px;font-size:12px;color:#888;text-decoration:none;">Categories</a></li>
                        <li><a asp-controller="Manufacturer" asp-action="Index" style="display:block;padding:7px 16px;font-size:12px;color:#888;text-decoration:none;">Developers</a></li>
                    </ul>
                </li>
            }
            @if (User.Identity!.IsAuthenticated)
            {
                <li><a asp-area="Identity" asp-page="/Account/Manage/Index">Account</a></li>
                <li>
                    <form asp-area="Identity" asp-page="/Account/Logout" method="post" style="display:inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" style="background:none;border:none;padding:0;font-size:12px;color:#888;cursor:pointer;">Sign out</button>
                    </form>
                </li>
            }
            else
            {
                <li><a asp-area="Identity" asp-page="/Account/Login" class="sf-nav-cta">Sign in</a></li>
            }
            <li><a asp-controller="Cart" asp-action="Index" class="sf-nav-cart">Cart</a></li>
        </ul>
    </nav>

    @RenderBody()

    <footer class="sf-footer">
        <span class="sf-footer-copy">&copy; 2026 WebshopShop</span>
        <ul class="sf-footer-links">
            <li><a asp-controller="Home" asp-action="Privacy">Privacy</a></li>
            <li><a href="#">Terms</a></li>
            <li><a href="#">Help</a></li>
        </ul>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>