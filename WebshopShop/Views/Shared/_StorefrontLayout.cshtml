<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — WebshopShop</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/storefront.css" asp-append-version="true" />
</head>
<body class="storefront">

    <nav class="sf-nav">
        <a class="sf-nav-brand" asp-controller="Home" asp-action="Index">WebshopShop</a>
        <ul class="sf-nav-links">
            <li><a asp-controller="Home" asp-action="Index">Browse</a></li>
            @if (User.IsInRole("Admin"))
            {
            <li class="sf-nav-dropdown">
                <a href="#">Admin ▾</a>
                <ul class="sf-nav-dropdown-menu">
                    <li><a asp-controller="Item" asp-action="Index">Webshops</a></li>
                    <li><a asp-controller="Category" asp-action="Index">Categories</a></li>
                    <li><a asp-controller="Manufacturer" asp-action="Index">Developers</a></li>
                </ul>
            </li>
            }
            @if (User.Identity!.IsAuthenticated)
            {
            <li><a asp-area="Identity" asp-page="/Account/Manage/Index">Account</a></li>
            <li>
                <form asp-area="Identity" asp-page="/Account/Logout" method="post" style="display:inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" style="background:none; border:none; padding:0; font-size:13px; color:#888; cursor:pointer; font-family:'DM Mono','Fira Mono',ui-monospace,monospace; transition:color 0.15s;">Sign out</button>
                </form>
            </li>
            }
            else
            {
            <li><a asp-area="Identity" asp-page="/Account/Login" class="sf-nav-cta">Sign in</a></li>
            }
            <li><a asp-controller="Cart" asp-action="Index" class="sf-nav-cart">Cart</a></li>
        </ul>
    </nav>

    @RenderBody()

    <footer class="sf-footer">
        <span class="sf-footer-copy">&copy; 2026 WebshopShop</span>
        <ul class="sf-footer-links">
            <li><a asp-controller="Home" asp-action="Privacy">Privacy</a></li>
            <li><a href="#">Terms</a></li>
            <li><a href="#">Help</a></li>
        </ul>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>