<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Admin · WebshopShop</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/storefront.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="admin">

    <nav class="adm-nav">
        <a class="adm-nav-brand" asp-controller="Home" asp-action="Index">
            WebshopShop
            <span class="adm-nav-brand-sep">/</span>
            <span class="adm-nav-brand-section">Admin</span>
        </a>
        <ul class="adm-nav-links">
            <li class="adm-nav-dropdown">
                <a href="#">Admin ▾</a>
                <ul class="adm-nav-dropdown-menu">
                    <li><a asp-controller="Item" asp-action="Index">Webshops</a></li>
                    <li><a asp-controller="Category" asp-action="Index">Categories</a></li>
                    <li><a asp-controller="Manufacturer" asp-action="Index">Developers</a></li>
                    <li><a asp-controller="Admin" asp-action="Orders">Orders</a></li>
                    <li><a asp-controller="Admin" asp-action="Users">Users</a></li>
                    <li><a asp-controller="Admin" asp-action="Statistics">Statistics</a></li>
                </ul>
            </li>
            <li><a asp-controller="Home" asp-action="Index" class="adm-nav-store">← Store</a></li>
            @if (User.Identity!.IsAuthenticated)
            {
            <li>
                <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="adm-nav-danger">Sign out</button>
                </form>
            </li>
            }
        </ul>
    </nav>

    <div class="adm-page">
        <main>
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>