@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
    Layout = "_StorefrontLayout";
}

<div class="sf-page">
    <div class="sf-error">
        <p class="sf-error-code">Error</p>
        <h1 class="sf-error-title">Something went wrong</h1>
        <p class="sf-error-sub">
            An error occurred while processing your request. Please try again or head back to the homepage.
        </p>

        @if (Model.ShowRequestId)
        {
            <p class="sf-error-request">
                Request ID: <code>@Model.RequestId</code>
            </p>
        }

        <a href="/" class="sf-detail-btn">Back to Browse</a>
    </div>
</div>
